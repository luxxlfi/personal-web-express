<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,300;0,400;0,700;1,700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    <title>{{title}}</title>
    <link rel="stylesheet" href="../assets/css/style.css">

</head>

<body>
    {{> navbar}}

    <div class="service-card-container">
        <div class="service-card1">
            <div class="card"
                style="background-color:  rgba(240, 248, 255, 0.118); box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                <div class="card-header">
                    Quote
                </div>
                <div class="card-body">
                    <figure>
                        <blockquote class="blockquote">
                            <p>A well-known quote, contained in a blockquote element.</p>
                        </blockquote>
                        <figcaption class="blockquote-footer">
                            Someone famous in <cite title="Source Title">Source Title</cite>
                        </figcaption>
                    </figure>
                </div>
            </div>
        </div>
        <!-- CARD 2 -->
        <div class="service-card2">
            <div class="cardkiri">
                <div class="card"
                    style="width: 18rem; margin-bottom: 20px; background-color:  rgba(240, 248, 255, 0.118);box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                    <div class="card-body ">
                        <h5 class="card-title"><i class="fa-brands fa-tiktok"></i>
                            Tik-Tok</h5>
                        <p class="card-text">With supporting text below as a natural lead-in to additional content.</p>
                        <a href="#" class="btn" style="box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">Go somewhere</a>
                    </div>
                </div>
                <div class="card"
                    style="width: 18rem; background-color:  rgba(240, 248, 255, 0.118); box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fa-brands fa-instagram"></i>Instagram</h5>
                        <p class="card-text">With supporting text below as a natural lead-in to additional content.</p>
                        <a href="#" class="btn" style="box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">Go somewhere</a>
                    </div>
                </div>
            </div>

            <div class="cardTengah">
                <div class="card-group" style="width: 300px; height: 395px; margin-left: 20px; ">
                    <div class="card"
                        style="background-color:  rgba(240, 248, 255, 0.118); box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                        <img src="../assets/img/flow.jpeg" class="card-img-top" alt="..." style="height: 200px;">
                        <div class="card-body">
                            <h5 class="card-title">Card title</h5>
                            <p class="card-text">This is a wider card with supporting text below as a natural lead-in to
                                additional content. This content is a little bit longer.</p>
                            <p class="card-text"><small class="text-body-secondary">Last updated 3 mins ago</small></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="cardkanan">
                <div class="card mb-3"
                    style="margin-left: 20px; background-color:  rgba(240, 248, 255, 0.118); box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fa-brands fa-telegram"></i>Telegtam</h5>
                        <p class="card-text">With supporting text below as a natural lead-in to additional content.</p>
                    </div>
                </div>
                <div class="cardkananisi">
                    <div class="card w-50"
                        style="margin-left: 20px;background-color:  rgba(240, 248, 255, 0.118); box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fa-brands fa-pinterest"></i>Pinterest</h5>
                            <p class="card-text">With supporting text below as a natural lead-in to additional content.
                            </p>
                        </div>
                    </div>
                    <div class="card w-50"
                        style="margin-left: 20px;background-color:  rgba(240, 248, 255, 0.118);box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fa-brands fa-whatsapp"></i>Whatsapp</h5>
                            <p class="card-text">With supporting text below as a natural lead-in to additional content.
                            </p>
                        </div>
                    </div>

                </div>
                <div class="card mb-3"
                    style="margin-left: 20px; margin-top: 20px; height: 160px; background-color:  rgba(240, 248, 255, 0.118); box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fa-brands fa-youtube"></i>Youtube</h5>
                        <p class="card-text">With supporting text below as a natural lead-in to additional content.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>

</body>

</html>